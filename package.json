{
  "name": "techhub-monorepo",
  "version": "1.0.0",
  "description": "TechHub - E-commerce application with React frontend and Express backend",
  "private": true,
  "scripts": {
    "dev": "npm run dev --workspace=frontend & npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "frontend": "npm --prefix frontend run dev",
    "backend": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend start",
    "lint": "npm run lint --workspace=frontend"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC"
}
